@model GameStore.Web.Models.CategoryBulkEditViewModel

<h2>Manage Categories</h2>

<div class="card mb-4">
    <div class="card-body">
        <h5>Add New Category</h5>
        <form asp-action="InlineAdd" method="post" class="row row-cols-lg-auto g-3 align-items-center">
            <div class="col-12">
                <input name="Name" class="form-control" placeholder="Category Name" required />
            </div>
            <div class="col-12">
                <button type="submit" class="btn btn-primary">Add</button>
            </div>
        </form>
    </div>
</div>

<hr />

<form asp-action="BulkUpdate" method="post">
    <table class="table">
        <thead>
            <tr>
                <th>Category Name</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Categories.Count == 0)
            {
                <tr>
                    <td class="text-center text-muted">No categories yet. Use the form above to add one.</td>
                </tr>
            }
            else
            {
                @for (int i = 0; i < Model.Categories.Count; i++)
                {
                    <tr>
                        <input type="hidden" asp-for="Categories[i].Id" />
                        <td>
                            <input asp-for="Categories[i].Name" class="form-control" />
                            <span asp-validation-for="Categories[i].Name" class="text-danger"></span>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>

    <div class="form-group mt-3">
        @if (Model.Categories.Count > 0)
        {
            <button type="submit" class="btn btn-success">Update All Categories</button>
        }
        <a asp-controller="Games" asp-action="Index" class="btn btn-secondary">Back to Games List</a>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}